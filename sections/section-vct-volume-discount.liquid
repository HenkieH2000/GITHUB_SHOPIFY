{% comment %}
  VCT Volume Discount Table — tiered pricing incentive
  Place inside product page template or as a standalone section.
  Configurable in theme editor.
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading | default: 'Bestel meer, bespaar meer'
  assign sub = section.settings.subtext
-%}

<div class="vct-volume-section vct-reveal">
  <div class="vct-volume__inner page-width">
    <h3 class="vct-volume__heading">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
      {{ heading }}
    </h3>
    {%- if sub != blank -%}
      <p class="vct-volume__sub">{{ sub }}</p>
    {%- endif -%}

    <div class="vct-volume__table" role="table">
      <div class="vct-volume__row vct-volume__row--header" role="row">
        <div role="columnheader">Aantal</div>
        <div role="columnheader">Korting</div>
        <div role="columnheader">Besparing</div>
      </div>
      {%- for block in section.blocks -%}
        {%- if block.type == 'tier' -%}
          {%- assign is_popular = block.settings.popular -%}
          <div class="vct-volume__row{% if is_popular %} vct-volume__row--popular{% endif %}" role="row" {{ block.shopify_attributes }}>
            <div role="cell">
              <strong>{{ block.settings.qty_label }}</strong>
              {%- if is_popular -%}
                <span class="vct-vol-badge">Populairste keuze</span>
              {%- endif -%}
            </div>
            <div role="cell" class="vct-vol-discount">{{ block.settings.discount_label }}</div>
            <div role="cell" class="vct-vol-saving">{{ block.settings.saving_label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.note != blank -%}
      <p class="vct-volume__note">{{ section.settings.note }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "VCT Volume Korting",
  "tag": "section",
  "class": "vct-section-volume-discount",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Bestel meer, bespaar meer"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtekst",
      "default": "Kortingen worden automatisch toegepast in de winkelwagen"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Voetnoot",
      "default": "* Kortingen zijn al inbegrepen in de getoonde prijzen"
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Kortingstier",
      "settings": [
        {
          "type": "text",
          "id": "qty_label",
          "label": "Hoeveelheid",
          "default": "1 stuk"
        },
        {
          "type": "text",
          "id": "discount_label",
          "label": "Korting",
          "default": "0%"
        },
        {
          "type": "text",
          "id": "saving_label",
          "label": "Besparing",
          "default": "—"
        },
        {
          "type": "checkbox",
          "id": "popular",
          "label": "Markeer als populairste keuze",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VCT Volume Korting",
      "blocks": [
        {"type": "tier", "settings": {"qty_label": "1 stuk",   "discount_label": "0%",  "saving_label": "—",        "popular": false}},
        {"type": "tier", "settings": {"qty_label": "2 stuks",  "discount_label": "5%",  "saving_label": "€2 – €8",  "popular": false}},
        {"type": "tier", "settings": {"qty_label": "3+ stuks", "discount_label": "10%", "saving_label": "€5 – €20", "popular": true}},
        {"type": "tier", "settings": {"qty_label": "5+ stuks", "discount_label": "15%", "saving_label": "€10 – €40","popular": false}}
      ]
    }
  ]
}
{% endschema %}
