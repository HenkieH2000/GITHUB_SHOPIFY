<script>
(function () {
  'use strict';

  var GA4_ID = 'G-X0F35QQYBP';

  var CFG = {
    coupon      : '{{ fixed_coupon }}',
    klaviyoKey  : 'Yj5QDm',
    klaviyoList : 'XzqxwP',
    countdown   : 600,
    ckSeen      : 'vct_popup_seen',
    ckSub       : 'vct_subscribed',
    ckDays      : 7,
    mobileDelay : 8000
  };

  var S = {
    step: 1, timer: null,
    secs: CFG.countdown, shown: false, exitBound: false
  };

  function g(id) { return document.getElementById(id); }

  var el = {
    overlay   : g('vcp'),
    closeBtn  : g('vcp-x'),
    steps     : { 1: g('vcp-s1'), 2: g('vcp-s2'), 3: g('vcp-s3') },
    mysteryBtn: g('vcp-mystery-btn'),
    decline   : g('vcp-decline'),
    back      : g('vcp-back'),
    submitBtn : g('vcp-submitbtn'),
    timerEl   : g('vcp-timer-cnt'),
    emailInp  : g('vcp-email'),
    shopBtn   : g('vcp-shopbtn')
  };

  function isMobile() {
    return window.innerWidth <= 640 || /Mobi|Android/i.test(navigator.userAgent);
  }

  // ── GA4 event helper ────────────────────────────────────────────────────────
  function trackEvent(name, params) {
  // GA4
  try {
    if (typeof gtag === 'function') {
      gtag('event', name, params);
    }
  } catch(e) {}
  // Shopify Analytics
  try {
    if (typeof analytics !== 'undefined' && typeof analytics.publish === 'function') {
      analytics.publish(name, params);
    }
  } catch(e) {}
}

  function setCk(n, v, d) {
    var e = new Date();
    e.setTime(e.getTime() + d * 86400000);
    document.cookie = n + '=' + encodeURIComponent(v) +
      '; expires=' + e.toUTCString() + '; path=/; SameSite=Lax';
  }
  function getCk(n) {
    var m = document.cookie.match(
      new RegExp('(?:^|; )' + n.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + '=([^;]*)')
    );
    return m ? decodeURIComponent(m[1]) : null;
  }

  function show() {
    if (S.shown || getCk(CFG.ckSub) || getCk(CFG.ckSeen)) return;
    S.shown = true;
    el.overlay.classList.add('vcp-show');
    el.overlay.removeAttribute('aria-hidden');
    document.body.classList.add('vcp-noscroll');
    trackEvent('popup_shown', {
      device: isMobile() ? 'mobile' : 'desktop'
    });
  }

  function hide() {
    el.overlay.classList.remove('vcp-show');
    el.overlay.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('vcp-noscroll');
    stopTimer();
    setCk(CFG.ckSeen, '1', CFG.ckDays);
  }

  function goStep(n) {
    var cur = el.steps[S.step];
    var nxt = el.steps[n];
    if (cur) cur.classList.remove('vcp-on');
    S.step = n;
    if (nxt) nxt.classList.add('vcp-on');
  }

  function goToEmail() {
    goStep(2);
    startTimer();
    setTimeout(function () { el.emailInp.focus(); }, 50);
    trackEvent('popup_knop1_geklikt', {
      device: isMobile() ? 'mobile' : 'desktop'
    });
  }

  function tick() {
    var m = Math.floor(S.secs / 60);
    var s = S.secs % 60;
    el.timerEl.textContent =
      (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
    if (S.secs === 0) el.timerEl.style.setProperty('color', '#EF4444', 'important');
  }
  function startTimer() {
    S.secs = CFG.countdown;
    tick();
    stopTimer();
    S.timer = setInterval(function () {
      S.secs = Math.max(0, S.secs - 1);
      tick();
      if (S.secs === 0) stopTimer();
    }, 1000);
  }
  function stopTimer() {
    if (S.timer) { clearInterval(S.timer); S.timer = null; }
  }

  function valid(inp) {
    var ok = (/^[^\s@]+@[^\s@]+\.[^\s@]+$/).test(inp.value.trim());
    inp.classList.toggle('vcp-err', !ok);
    return ok;
  }

  function subscribe(email, cb) {
    fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + CFG.klaviyoKey, {
      method  : 'POST',
      headers : {
        'Content-Type' : 'application/json',
        'revision'     : '2023-12-15'
      },
      body: JSON.stringify({
        data: {
          type: 'subscription',
          attributes: {
            profile: {
              data: {
                type: 'profile',
                attributes: {
                  email: email,
                  properties: {
                    source: 'popup',
                    coupon_used: CFG.coupon
                  }
                }
              }
            }
          },
          relationships: {
            list: {
              data: {
                type : 'list',
                id   : CFG.klaviyoList
              }
            }
          }
        }
      })
    })
    .then(function(res) {
      console.log('Klaviyo status:', res.status);
      cb();
    })
    .catch(function(err) {
      console.error('Klaviyo fout:', err);
      cb();
    });
  }

  function handleSubmit() {
    if (!valid(el.emailInp)) return;
    el.submitBtn.disabled = true;
    el.submitBtn.classList.add('vcp-loading');
    subscribe(el.emailInp.value.trim(), function () {
      doSuccess();
    });
  }

  function doSuccess() {
    el.submitBtn.disabled = false;
    el.submitBtn.classList.remove('vcp-loading');
    stopTimer();
    goStep(3);
    setCk(CFG.ckSub, '1', 365);
    trackEvent('popup_email_ingevuld', {
      device: isMobile() ? 'mobile' : 'desktop'
    });
  }

  function initTriggers() {
    if (getCk(CFG.ckSub) || getCk(CFG.ckSeen)) return;
    var pages = (parseInt(sessionStorage.getItem('vct_pg') || '0', 10)) + 1;
    sessionStorage.setItem('vct_pg', pages);
    if (isMobile()) {
      if (pages >= 2) setTimeout(show, CFG.mobileDelay);
    } else {
      if (!S.exitBound) {
        S.exitBound = true;
        document.addEventListener('mouseleave', function (e) {
          if (e.clientY < 5) show();
        });
      }
      if (pages >= 2) setTimeout(show, 15000);
    }
  }

  el.closeBtn.addEventListener('click', hide);
  el.overlay.addEventListener('click', function (e) {
    if (e.target === el.overlay) hide();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && el.overlay.classList.contains('vcp-show')) hide();
  });
  el.mysteryBtn.addEventListener('click', goToEmail);
  el.decline.addEventListener('click', hide);
  el.back.addEventListener('click', function () { goStep(1); stopTimer(); });
  el.submitBtn.addEventListener('click', handleSubmit);
  el.shopBtn.addEventListener('click', hide);
  el.emailInp.addEventListener('blur', function () { valid(el.emailInp); });
  el.emailInp.addEventListener('input', function () {
    if (el.emailInp.classList.contains('vcp-err')) valid(el.emailInp);
  });
  el.emailInp.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') handleSubmit();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTriggers);
  } else {
    initTriggers();
  }

}());
</script>

