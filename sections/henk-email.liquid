        <div class="vcp-rright">
          <span class="vcp-stars" aria-hidden="true">★★★★★</span>
          <span class="vcp-rlbl">FeedbackCompany · 5.000+ klanten</span>
        </div>
      </div>
    </div>

    <div id="vcp-right">

      <!-- Stap 1 -->
      <div id="vcp-s1" class="vcp-step vcp-on">
        <h3 id="vcp-s1-head">Ontvang jouw<br><em>mystery korting</em></h3>
        <p id="vcp-s1-sub">Schrijf je in op onze nieuwsbrief en ontgrendel een exclusieve kortingscode.</p>
        <button id="vcp-mystery-btn" aria-label="Mystery korting claimen">
          <span id="vcp-mystery-icon" aria-hidden="true">🔮</span>
          <span id="vcp-mystery-label">Claim mijn mystery korting</span>
          <span id="vcp-mystery-hint">Klik en ontdek wat je bespaart</span>
        </button>
        <button id="vcp-decline">Nee, ik betaal liever de volle prijs.</button>
      </div>

