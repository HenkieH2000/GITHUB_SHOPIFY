{% comment %}
  Snippet: snippets/henk-bundle.liquid
  Gebruik: {% render 'henk-bundle' %}
{% endcomment %}

{% assign minimum_bundle_discount = 5 %}

<div class="hb-wrapper"
     data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=12"
     data-main-variant="{{ product.selected_or_first_available_variant.id }}"
     data-main-price="{{ product.selected_or_first_available_variant.price }}">

  <div class="hb-inner">
    <div class="hb-main-product">
      <div class="hb-main-img-wrap">
        <img src="{{ product.featured_image | img_url: '400x' }}" alt="{{ product.title }}">
      </div>
      <div class="hb-main-info">
        <span class="hb-main-vendor">{{ product.vendor }}</span>
        <span class="hb-main-title">{{ product.title }}</span>
        <span class="hb-main-price">{{ product.price | money | replace: ',00', ',-' | remove: '€' | strip }}</span>
      </div>
      <div class="hb-plus">+</div>
    </div>
    <div class="hb-upsell-grid" id="hb-upsell-grid"></div>
  </div>

  <div class="hb-alt-panel" id="hb-alt-panel" style="display:none;">
    <div class="hb-alt-header">
      <span class="hb-alt-label">Kies een alternatief</span>
      <span class="hb-alt-close" id="hb-alt-close">✕</span>
    </div>
    <div class="hb-alt-scroll-wrap">
      <button class="hb-alt-arrow hb-alt-arrow--left" id="hb-alt-prev" aria-label="Vorige">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="hb-alt-scroll" id="hb-alt-scroll"></div>
      <button class="hb-alt-arrow hb-alt-arrow--right" id="hb-alt-next" aria-label="Volgende">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>

  <div class="hb-footer" id="hb-footer" style="display:none;">
    <div class="hb-footer-left">
      <div class="hb-total-wrap">
        <span class="hb-total-new" id="hb-total-new"></span>
        <span class="hb-total-old" id="hb-total-old"></span>
      </div>
      <span class="hb-stock">✓ Geselecteerde producten op voorraad</span>
    </div>
    <button class="hb-btn" id="hb-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57L23 6H6"/></svg>
      Geselecteerde producten toevoegen
    </button>
  </div>

</div>

<div style="display:none">
  {% if recommendations.performed and recommendations.products_count > 0 %}
    {% for item in recommendations.products limit: 12 %}
      {% assign item_variant = item.selected_or_first_available_variant %}
      {% assign truly_available = false %}
      {% if item_variant.available %}
        {% if item_variant.inventory_management == blank %}
          {% comment %}Geen voorraadbeheer = altijd te koop{% endcomment %}
          {% assign truly_available = true %}
        {% elsif item_variant.inventory_policy == 'continue' %}
          {% comment %}Oversell toegestaan = altijd te koop{% endcomment %}
          {% assign truly_available = true %}
        {% elsif item_variant.inventory_quantity > 0 %}
          {% comment %}Daadwerkelijk op voorraad{% endcomment %}
          {% assign truly_available = true %}
        {% endif %}
      {% endif %}
      {% if truly_available %}
        {% assign base_price = item.price %}
        {% assign compare_price = item.compare_at_price %}
        {% assign active_discount_percentage = 0.0 %}
        {% if compare_price > base_price %}
          {% assign price_difference = compare_price | minus: base_price %}
          {% assign active_discount_percentage = price_difference | times: 100.0 | divided_by: compare_price | ceil %}
        {% endif %}
        {% if active_discount_percentage > minimum_bundle_discount %}
          {% assign final_percentage_to_apply = active_discount_percentage %}
          {% assign display_old_price = compare_price %}
        {% else %}
          {% assign final_percentage_to_apply = minimum_bundle_discount %}
          {% assign display_old_price = base_price %}
        {% endif %}
        {% assign discount_factor = 100.0 | minus: final_percentage_to_apply | divided_by: 100.0 %}
        {% assign final_discounted_price = base_price | times: discount_factor | round %}
        <div class="hb-source-card"
             data-variant-id="{{ item_variant.id }}"
             data-price="{{ final_discounted_price }}"
             data-old-price="{{ display_old_price }}"
             data-pct="{{ final_percentage_to_apply }}"
             data-title="{{ item.title | escape }}"
             data-vendor="{{ item.vendor | escape }}"
             data-url="{{ item.url }}"
             data-img="{{ item.featured_image | img_url: '400x' }}">
        </div>
      {% endif %}
    {% endfor %}
  {% endif %}

  {% assign product_type = product.type %}
  {% for collection in collections %}
    {% if collection.handle == product_type or collection.title == product_type %}
      {% for fallback in collection.products limit: 12 %}
        {% if fallback.id != product.id %}
          {% assign fb_variant = fallback.selected_or_first_available_variant %}
          {% assign fb_truly_available = false %}
          {% if fb_variant.available %}
            {% if fb_variant.inventory_management == blank %}
              {% assign fb_truly_available = true %}
            {% elsif fb_variant.inventory_policy == 'continue' %}
              {% assign fb_truly_available = true %}
            {% elsif fb_variant.inventory_quantity > 0 %}
              {% assign fb_truly_available = true %}
            {% endif %}
          {% endif %}
          {% if fb_truly_available %}
            {% assign fb_base = fallback.price %}
            {% assign fb_compare = fallback.compare_at_price %}
            {% assign fb_pct = minimum_bundle_discount %}
            {% assign fb_old = fb_base %}
            {% if fb_compare > fb_base %}
              {% assign fb_diff = fb_compare | minus: fb_base %}
              {% assign fb_active = fb_diff | times: 100.0 | divided_by: fb_compare | ceil %}
              {% if fb_active > minimum_bundle_discount %}
                {% assign fb_pct = fb_active %}
                {% assign fb_old = fb_compare %}
              {% endif %}
            {% endif %}
            {% assign fb_factor = 100.0 | minus: fb_pct | divided_by: 100.0 %}
            {% assign fb_price = fb_base | times: fb_factor | round %}
            <div class="hb-source-card hb-fallback-card"
                 data-variant-id="{{ fb_variant.id }}"
                 data-price="{{ fb_price }}"
                 data-old-price="{{ fb_old }}"
                 data-pct="{{ fb_pct }}"
                 data-title="{{ fallback.title | escape }}"
                 data-vendor="{{ fallback.vendor | escape }}"
                 data-url="{{ fallback.url }}"
                 data-img="{{ fallback.featured_image | img_url: '400x' }}">
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% assign glossio_collection = collections['glossio'] %}
  {% if product.vendor == 'Glossio' %}
    {% for gp in glossio_collection.products limit: 12 %}
      {% if gp.id != product.id %}
        {% assign gp_variant = gp.selected_or_first_available_variant %}
        {% assign gp_truly_available = false %}
        {% if gp_variant.available %}
          {% if gp_variant.inventory_management == blank %}
            {% assign gp_truly_available = true %}
          {% elsif gp_variant.inventory_policy == 'continue' %}
            {% assign gp_truly_available = true %}
          {% elsif gp_variant.inventory_quantity > 0 %}
            {% assign gp_truly_available = true %}
          {% endif %}
        {% endif %}
        {% if gp_truly_available %}
          {% assign gp_base = gp.price %}
          {% assign gp_compare = gp.compare_at_price %}
          {% assign gp_pct = minimum_bundle_discount %}
          {% assign gp_old = gp_base %}
          {% if gp_compare > gp_base %}
            {% assign gp_diff = gp_compare | minus: gp_base %}
            {% assign gp_active = gp_diff | times: 100.0 | divided_by: gp_compare | ceil %}
            {% if gp_active > minimum_bundle_discount %}
              {% assign gp_pct = gp_active %}
              {% assign gp_old = gp_compare %}
            {% endif %}
          {% endif %}
          {% assign gp_factor = 100.0 | minus: gp_pct | divided_by: 100.0 %}
          {% assign gp_price = gp_base | times: gp_factor | round %}
          <div class="hb-source-card hb-glossio-card"
               data-variant-id="{{ gp_variant.id }}"
               data-price="{{ gp_price }}"
               data-old-price="{{ gp_old }}"
               data-pct="{{ gp_pct }}"
               data-title="{{ gp.title | escape }}"
               data-vendor="{{ gp.vendor | escape }}"
               data-url="{{ gp.url }}"
               data-img="{{ gp.featured_image | img_url: '400x' }}">
          </div>
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endif %}
</div>

<style>
  .hb-wrapper { background: #f4f4f4; border: 1px solid #e8eaf0; border-radius: 10px; padding: 16px; margin: 16px 0; font-family: inherit; }
  .hb-inner { display: flex; gap: 12px; align-items: flex-start; }
  .hb-main-product { flex: 1; min-width: 0; display: flex; flex-direction: column; align-items: center; position: relative; }
  .hb-main-img-wrap { width: 100%; aspect-ratio: 1; background: #fff; border-radius: 10px; border: 1px solid #e8eaf0; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .hb-main-img-wrap img { width: 100%; height: 100%; object-fit: contain; padding: 8px; box-sizing: border-box; }
  .hb-main-info { display: flex; flex-direction: column; gap: 2px; margin-top: 8px; text-align: center; width: 100%; }
  .hb-main-vendor { font-size: 11px; color: #6b7280; font-weight: 500; }
  .hb-main-title { font-size: 11px; font-weight: 600; color: #030a22; line-height: 1.3; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
  .hb-main-price { font-size: 13px; font-weight: 800; color: #030a22; margin-top: 2px; }
  .hb-plus { position: absolute; right: -18px; top: 38%; width: 24px; height: 24px; background: #fff; border: 1px solid #e8eaf0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; color: #6b7280; z-index: 1; transform: translateY(-50%); }
  .hb-upsell-grid { display: flex; gap: 12px; flex: 3; min-width: 0; }
  .hb-card { flex: 1; background: #fff; border: 1px solid #e8eaf0; border-radius: 10px; padding: 10px; display: flex; flex-direction: column; gap: 5px; cursor: pointer; user-select: none; transition: border-color 0.2s, background 0.2s; min-width: 0; position: relative; }
  .hb-card:hover { border-color: #FF7E00; }
  .hb-card.is-checked { border-color: #FF7E00; background: #fffaf5; }
  .hb-card:focus, .hb-card *:focus { outline: none; box-shadow: none; }
  .hb-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 4px; }
  .hb-custom-checkbox { display: block; cursor: pointer; flex-shrink: 0; }
  .hb-custom-checkbox input { display: none; }
  .hb-checkmark { width: 20px; height: 20px; border-radius: 5px; border: 2px solid #d1d5db; background: #fff; display: flex; align-items: center; justify-content: center; transition: all 0.15s ease; }
  .hb-checkmark svg { color: #fff; opacity: 0; transition: opacity 0.15s ease; }
  .hb-custom-checkbox input:checked + .hb-checkmark { background: #FF7E00; border-color: #FF7E00; }
  .hb-custom-checkbox input:checked + .hb-checkmark svg { opacity: 1; }
  .hb-discount-badge { background: #FE0000; color: #fff; font-size: 10px; font-weight: 700; padding: 2px 5px; border-radius: 5px; white-space: nowrap; }
  .hb-discount-badge--abs { display: none; }
  .hb-card-img { width: 100%; aspect-ratio: 1; object-fit: contain; border-radius: 6px; display: block; padding: 4px; box-sizing: border-box; }
  .hb-card-vendor { font-size: 10px; color: #6b7280; font-weight: 500; }
  .hb-card-title { font-size: 11px; font-weight: 600; color: #030a22; line-height: 1.3; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
  .hb-card-prices { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
  .hb-price-current { font-size: 12px; font-weight: 800; color: #030a22; }
  .hb-price-old { font-size: 10px; color: #9ca3af; text-decoration: line-through; }
  .hb-card-body-wrap { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 3px; }
  .hb-alt-btn { display: inline-flex; align-items: center; gap: 3px; font-size: 10px; color: #FF7E00; font-weight: 500; cursor: pointer; text-decoration: underline; text-underline-offset: 2px; margin-top: auto; line-height: 1.4; }
  .hb-alt-btn:hover { color: #e06e00; }
  .hb-info-btn { position: absolute; bottom: 8px; right: 8px; width: 22px; height: 22px; border-radius: 50%; background: #fff3e8; border: none; display: flex; align-items: center; justify-content: center; color: #FF7E00; font-size: 11px; font-weight: 700; font-family: Georgia, serif; cursor: pointer; text-decoration: none; line-height: 1; transition: background 0.15s, color 0.15s; z-index: 2; }
  .hb-info-btn:hover { background: #FF7E00; border: none; color: #fff !important; }
  .hb-alt-panel { margin-top: 12px; border: 1px solid #e8eaf0; border-radius: 10px; overflow: hidden; background: #fff; }
  .hb-alt-header { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; border-bottom: 1px solid #e8eaf0; }
  .hb-alt-label { font-size: 12px; font-weight: 700; color: #030a22; }
  .hb-alt-close { font-size: 13px; color: #9ca3af; cursor: pointer; line-height: 1; padding: 2px 4px; }
  .hb-alt-close:hover { color: #030a22; }
  .hb-alt-scroll-wrap { display: flex; align-items: center; }
  .hb-alt-scroll { display: flex; gap: 8px; padding: 12px; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; flex: 1; scroll-behavior: smooth; }
  .hb-alt-scroll::-webkit-scrollbar { display: none; }
  .hb-alt-arrow { display: none !important; }
  @media (min-width: 641px) {
    .hb-wrapper .hb-alt-arrow { display: flex !important; align-items: center !important; justify-content: center !important; flex-shrink: 0 !important; width: 26px !important; height: 26px !important; min-width: 0 !important; min-height: 0 !important; max-width: 26px !important; max-height: 26px !important; background: #f9fafb !important; border: 1px solid #e8eaf0 !important; border-radius: 50% !important; cursor: pointer !important; color: #6b7280 !important; transition: border-color 0.2s, color 0.2s !important; margin: 0 4px !important; padding: 0 !important; box-shadow: none !important; font-size: 0 !important; line-height: 0 !important; }
    .hb-wrapper .hb-alt-arrow:hover { border-color: #d1d5db !important; color: #030a22 !important; background: #f3f4f6 !important; }
    .hb-wrapper .hb-alt-arrow:disabled { opacity: 0.3 !important; cursor: default !important; pointer-events: none !important; }
    .hb-wrapper .hb-alt-arrow svg { width: 12px !important; height: 12px !important; flex-shrink: 0 !important; }
  }
  .hb-alt-card { flex-shrink: 0; width: 110px; border: 1px solid #e8eaf0; border-radius: 10px; padding: 8px; cursor: pointer; position: relative; transition: border-color 0.2s; }
  .hb-alt-card:hover { border-color: #FF7E00; }
  .hb-alt-card--active { border-color: #FF7E00; background: #fffaf5; pointer-events: none; }
  .hb-alt-card img { width: 100%; aspect-ratio: 1; object-fit: contain; border-radius: 6px; display: block; }
  .hb-alt-discount-badge { position: absolute; top: 6px; right: 6px; background: #FE0000; color: #fff; font-size: 9px; font-weight: 700; padding: 2px 4px; border-radius: 4px; }
  .hb-alt-vendor { display: block; font-size: 9px; color: #6b7280; margin-top: 5px; }
  .hb-alt-title { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; font-size: 10px; font-weight: 600; color: #030a22; line-height: 1.3; margin: 2px 0 4px; }
  .hb-alt-prices { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
  .hb-footer { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-top: 16px; padding-top: 16px; border-top: 1px solid #e8eaf0; flex-wrap: wrap; }
  .hb-footer-left { display: flex; flex-direction: column; gap: 3px; }
  .hb-total-wrap { display: flex; align-items: baseline; gap: 8px; }
  .hb-total-new { font-size: 22px; font-weight: 800; color: #030a22; }
  .hb-total-old { font-size: 15px; color: #9ca3af; text-decoration: line-through; }
  .hb-stock { font-size: 12px; color: #00a000; font-weight: 500; }
  .hb-btn { background: #FF7E00 !important; color: #fff !important; border: none !important; border-radius: 100px !important; padding: 12px 24px !important; font-size: 13px !important; font-weight: 700 !important; cursor: pointer !important; display: inline-flex !important; align-items: center !important; gap: 8px !important; transition: background 0.2s !important; white-space: nowrap !important; width: auto !important; min-width: 0 !important; height: auto !important; box-shadow: none !important; line-height: normal !important; }
  .hb-btn:hover { background: #e06e00 !important; }
  .hb-btn:disabled { background: #ccc !important; cursor: default !important; }
  @media (max-width: 640px) {
    .hb-wrapper { padding: 12px; overflow: hidden; }
    .hb-inner { flex-direction: column; gap: 8px; }
    .hb-main-product { flex-direction: row; width: 100%; flex: none; gap: 12px; align-items: center; }
    .hb-main-img-wrap { width: 80px; height: 80px; flex-shrink: 0; aspect-ratio: unset; }
    .hb-main-info { text-align: left; margin-top: 0; flex: 1; }
    .hb-plus { position: static; transform: none; margin: 0; flex-shrink: 0; }
    .hb-upsell-grid { flex-direction: column; width: 100%; gap: 8px; flex: none; }
    .hb-card { flex-direction: row; align-items: center; gap: 8px; position: relative; padding: 10px; box-sizing: border-box; }
    .hb-card-top { flex-direction: column; align-items: center; flex-shrink: 0; gap: 0; }
    .hb-card-top .hb-discount-badge { display: none; }
    .hb-card-img { width: 64px; height: 64px; flex-shrink: 0; aspect-ratio: unset; }
    .hb-card-title { padding-right: 40px; }
    .hb-discount-badge--abs { display: inline-block; position: absolute; top: 10px; right: 10px; }
    .hb-info-btn { bottom: 8px; right: 8px; top: auto; }
    .hb-footer { flex-direction: column; align-items: flex-start; }
    .hb-btn { width: 100% !important; justify-content: center !important; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const wrapper   = document.querySelector('.hb-wrapper');
  if (!wrapper) return;

  const grid      = document.getElementById('hb-upsell-grid');
  const footer    = document.getElementById('hb-footer');
  const btn       = document.getElementById('hb-btn');
  const totalNew  = document.getElementById('hb-total-new');
  const totalOld  = document.getElementById('hb-total-old');
  const altPanel  = document.getElementById('hb-alt-panel');
  const altScroll = document.getElementById('hb-alt-scroll');
  const altClose  = document.getElementById('hb-alt-close');
  const altPrev   = document.getElementById('hb-alt-prev');
  const altNext   = document.getElementById('hb-alt-next');
  const baseUrl   = wrapper.dataset.url;
  const compUrl   = baseUrl + '&intent=complementary';

  function getMainVariantId() {
    const liquidVariant = parseInt(wrapper.dataset.mainVariant);
    if (liquidVariant) return liquidVariant;

    const hidden = document.querySelector('input[name="id"][type="hidden"]');
    if (hidden && hidden.value) return parseInt(hidden.value);

    const anyInput = document.querySelector('[name="id"]');
    if (anyInput && anyInput.value) return parseInt(anyInput.value);

    return null;
  }

  let allCards = [];
  let slotData = [-1, -1, -1, -1, -1]; // 5 slots voor Glossio; niet-Glossio gebruikt alleen de eerste 3

  function money(cents) {
    const n = parseInt(cents);
    if (!n || isNaN(n)) return '';
    return (n / 100).toFixed(2).replace('.', ',').replace(',00', ',-');
  }

  function updateAltArrows() {
    if (!altPrev || !altNext) return;
    altPrev.disabled = altScroll.scrollLeft <= 0;
    altNext.disabled = altScroll.scrollLeft + altScroll.clientWidth >= altScroll.scrollWidth - 1;
  }

  if (altPrev) altPrev.addEventListener('click', () => altScroll.scrollBy({ left: -240, behavior: 'smooth' }));
  if (altNext) altNext.addEventListener('click', () => altScroll.scrollBy({ left: 240, behavior: 'smooth' }));
  altScroll.addEventListener('scroll', updateAltArrows);

  function buildCard(d, slotIndex) {
    const card = document.createElement('div');
    card.className = 'hb-card is-checked';
    card.dataset.variantId = d.variantId;
    card.dataset.price     = d.price;
    card.dataset.oldPrice  = d.oldPrice;

    card.innerHTML = `
      <div class="hb-card-top">
        <label class="hb-custom-checkbox" onclick="event.stopPropagation()">
          <input type="checkbox" class="hb-checkbox" checked>
          <span class="hb-checkmark">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
        </label>
        <span class="hb-discount-badge">-${d.pct}%</span>
      </div>
      <img class="hb-card-img" src="${d.img}" alt="${d.title}">
      <div class="hb-card-body-wrap">
        <span class="hb-card-vendor">${d.vendor}</span>
        <span class="hb-card-title">${d.title}</span>
        <div class="hb-card-prices">
          <span class="hb-price-current">${money(d.price)}</span>
          <span class="hb-price-old">${money(d.oldPrice)}</span>
        </div>
        <span class="hb-alt-btn">
          Kies alternatief
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      </div>
      <span class="hb-discount-badge hb-discount-badge--abs">-${d.pct}%</span>
      <a class="hb-info-btn" href="${d.url}" target="_blank" title="Bekijk productpagina" aria-label="Meer info over ${d.title}">i</a>`;

    card.querySelector('.hb-alt-btn').addEventListener('click', e => {
      e.stopPropagation();
      showAltPanel(slotIndex);
    });
    card.querySelector('.hb-info-btn').addEventListener('click', e => e.stopPropagation());
    card.querySelector('.hb-checkbox').addEventListener('change', function () {
      card.classList.toggle('is-checked', this.checked);
      updateTotals();
    });
    card.addEventListener('click', function (e) {
      if (e.target.closest('.hb-alt-btn')) return;
      if (e.target.closest('.hb-info-btn')) return;
      const cb = this.querySelector('.hb-checkbox');
      cb.checked = !cb.checked;
      this.classList.toggle('is-checked', cb.checked);
      updateTotals();
    });
    return card;
  }

  function showAltPanel(slotIndex) {
    altScroll.innerHTML = '';
    altPanel.dataset.slot = slotIndex;
    allCards.forEach((d, i) => {
      if (slotData.some((idx, s) => idx === i && s !== slotIndex)) return;
      const isCurrent = slotData[slotIndex] === i;
      const card = document.createElement('div');
      card.className = 'hb-alt-card' + (isCurrent ? ' hb-alt-card--active' : '');
      card.innerHTML = `
        <img src="${d.img}" alt="${d.title}">
        <div class="hb-alt-discount-badge">-${d.pct}%</div>
        <span class="hb-alt-vendor">${d.vendor}</span>
        <span class="hb-alt-title">${d.title}</span>
        <div class="hb-alt-prices">
          <span class="hb-price-current">${money(d.price)}</span>
          <span class="hb-price-old">${money(d.oldPrice)}</span>
        </div>`;
      if (!isCurrent) card.addEventListener('click', () => swapSlot(slotIndex, i));
      altScroll.appendChild(card);
    });
    altPanel.style.display = 'block';
    setTimeout(updateAltArrows, 50);
  }

  function swapSlot(slotIndex, newCardIndex) {
    const cards = grid.querySelectorAll('.hb-card');
    const wasChecked = cards[slotIndex]?.querySelector('.hb-checkbox')?.checked ?? true;
    slotData[slotIndex] = newCardIndex;
    const newCard = buildCard(allCards[newCardIndex], slotIndex);
    if (!wasChecked) { newCard.classList.remove('is-checked'); newCard.querySelector('.hb-checkbox').checked = false; }
    if (cards[slotIndex]) cards[slotIndex].replaceWith(newCard);
    altPanel.style.display = 'none';
    updateTotals();
  }

  altClose.addEventListener('click', () => altPanel.style.display = 'none');

  function updateTotals() {
    const mainPrice = parseInt(wrapper.dataset.mainPrice) || 0;
    let newTotal = mainPrice;
    let oldTotal = mainPrice;
    let any = false;

    grid.querySelectorAll('.hb-card').forEach(card => {
      if (card.querySelector('.hb-checkbox')?.checked) {
        newTotal += parseInt(card.dataset.price) || 0;
        oldTotal += parseInt(card.dataset.oldPrice) || 0;
        any = true;
      }
    });

    footer.style.display = any ? 'flex' : 'none';
    if (any) {
      totalNew.textContent = money(newTotal);
      totalOld.textContent = money(oldTotal);
    }
  }

  function parseSourceCards(html) {
    const el = document.createElement('div');
    el.innerHTML = html;
    return Array.from(el.querySelectorAll('.hb-source-card')).map(src => ({
      variantId : src.dataset.variantId,
      price     : src.dataset.price,
      oldPrice  : src.dataset.oldPrice,
      pct       : src.dataset.pct,
      title     : src.dataset.title,
      vendor    : src.dataset.vendor,
      url       : src.dataset.url,
      img       : src.dataset.img
    }));
  }

  function loadCards(url) {
    return fetch(url).then(r => r.text()).then(parseSourceCards).catch(() => []);
  }

  Promise.all([loadCards(compUrl), loadCards(baseUrl)])
  .then(([compData, stdData]) => {
    const seen = new Set();
    const fallbackData = parseSourceCards(document.documentElement.innerHTML)
      .filter(d => !!document.querySelector(`.hb-fallback-card[data-variant-id="${d.variantId}"]`));

    const glossioData = parseSourceCards(document.documentElement.innerHTML)
      .filter(d => !!document.querySelector(`.hb-glossio-card[data-variant-id="${d.variantId}"]`));

    for (const d of [...compData, ...stdData, ...fallbackData, ...glossioData]) {
      if (d.variantId && !seen.has(d.variantId)) {
        seen.add(d.variantId);
        allCards.push(d);
      }
    }

    // Verberg de hele widget als er geen beschikbare upsell-producten zijn
    if (allCards.length === 0) { wrapper.style.display = 'none'; return; }

    // Glossio-filter: als het hoofdproduct van Glossio is, alleen Glossio-producten tonen
    const mainVendor = {{ product.vendor | json }};
    const isGlossio = mainVendor && mainVendor.toLowerCase() === 'glossio';
    if (isGlossio) {
      allCards = allCards.filter(d => d.vendor && d.vendor.toLowerCase() === 'glossio');
      if (allCards.length === 0) { wrapper.style.display = 'none'; return; }
    }

    // Glossio toont 5 upsell-kaarten, alle andere merken tonen er 3
    const maxSlots = isGlossio ? 5 : 3;
    const count = Math.min(maxSlots, allCards.length);
    grid.innerHTML = '';
    for (let i = 0; i < count; i++) {
      slotData[i] = i;
      grid.appendChild(buildCard(allCards[i], i));
    }
    updateTotals();
  });

  function updateCartCount(cart) {
    document.querySelectorAll('[data-cart-count],[data-cart-item-count],.cart-count,.cart__count,.header__cart-count,.cart-count-bubble').forEach(el => {
      el.textContent = cart.item_count;
      el.setAttribute('data-count', cart.item_count);
      if (cart.item_count > 0) el.removeAttribute('hidden');
    });
  }

  function refreshDrawerContent() {
    const drawerEl = document.querySelector('cart-drawer, #CartDrawer, .cart-drawer');
    if (!drawerEl) return Promise.resolve();
    const sectionId = drawerEl.dataset.sectionId || drawerEl.id || 'cart-drawer';
    return fetch(`/?sections=${sectionId}`).then(r => r.json()).then(data => {
      const html = data[sectionId] || data[Object.keys(data)[0]];
      if (!html) return;
      const parser = new DOMParser();
      const newDoc = parser.parseFromString(html, 'text/html');
      for (const sel of ['.cart-drawer__item-list','.drawer__cart-items-wrapper','#cart-drawer-items','.cart-items','[data-cart-items]','.js-cart-items']) {
        const src = newDoc.querySelector(sel), tgt = document.querySelector(sel);
        if (src && tgt) { tgt.innerHTML = src.innerHTML; break; }
      }
      for (const sel of ['.cart-drawer__footer','.drawer__footer','#cart-drawer-footer','[data-cart-total]','.cart-subtotal']) {
        const src = newDoc.querySelector(sel), tgt = document.querySelector(sel);
        if (src && tgt) { tgt.innerHTML = src.innerHTML; break; }
      }
    }).catch(() => {});
  }

  function openCartDrawer() {
    const drawerEl = document.querySelector('cart-drawer');
    if (drawerEl) {
      if (typeof drawerEl.open === 'function') { drawerEl.open(); return; }
      drawerEl.setAttribute('open', ''); drawerEl.removeAttribute('aria-hidden'); return;
    }
    for (const sel of ['[data-cart-toggle]','[data-drawer-trigger="cart"]','.js-drawer-open-cart','#cart-icon-bubble','[aria-label*="winkelwagen" i]','.cart-toggle','.cart__toggle','.header__cart','.site-header__cart']) {
      const el = document.querySelector(sel);
      if (el) { el.click(); return; }
    }
    for (const [name, target] of [['CartDrawer:open', document.body],['cart:open', document],['cart:toggle', document],['theme:cart:open', document],['open-cart', document],['cartOpen', document]]) {
      target.dispatchEvent(new CustomEvent(name, { bubbles: true }));
    }
  }

  btn.addEventListener('click', function () {
    const mainVariantId = getMainVariantId();
    const items = [];

    if (mainVariantId) items.push({ id: mainVariantId, quantity: 1 });

    grid.querySelectorAll('.hb-card.is-checked').forEach(card => {
      const id = parseInt(card.dataset.variantId);
      if (id && !isNaN(id)) {
        items.push({
          id,
          quantity: 1,
          properties: { _bundle: 'true' }
        });
      }
    });

    if (!items.length) return;

    const originalHTML = btn.innerHTML;
    btn.textContent = 'Toevoegen...';
    btn.disabled = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ items, attributes: { 'henk-bundle': 'true' } })
    })
    .then(r => {
      if (!r.ok) return r.json().then(e => { throw new Error(e.message || r.status); });
      return r.json();
    })
    .then(() => Promise.all([fetch('/cart.js').then(r => r.json()), refreshDrawerContent()]))
    .then(([cart]) => {
      updateCartCount(cart);
      document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true, detail: { cart } }));
      window.dispatchEvent(new CustomEvent('cart-update', { bubbles: true, detail: { cart } }));
      document.dispatchEvent(new CustomEvent('theme:cart:update', { bubbles: true, detail: { cart } }));
      openCartDrawer();
      btn.innerHTML = '✓ Toegevoegd!';
      setTimeout(() => { btn.innerHTML = originalHTML; btn.disabled = false; }, 2000);
    })
    .catch(err => {
      console.error('Cart fout:', err);
      btn.textContent = 'Fout: ' + (err.message || 'probeer opnieuw');
      setTimeout(() => { btn.innerHTML = originalHTML; btn.disabled = false; }, 3000);
    });
  });
});
</script>
