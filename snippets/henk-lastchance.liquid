            <span class="lc-cd-sep">:</span>
            <span class="lc-cd-num" id="lc-cd-s">00</span>
            <span class="lc-cd-unit">minuten</span>
          </div>
        </div>
      </div>

      <div class="lc-product" id="lc-product">
        <div class="lc-loading">
          <div class="lc-spinner"></div>
          <span>Even laden…</span>
        </div>
      </div>

      <!-- Alternatieve producten picker -->
      <div class="lc-alts" id="lc-alts" style="display:none;">
        <button class="lc-alts-toggle" id="lc-alts-toggle">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          Kies een ander product
          <svg class="lc-alts-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="lc-alts-drawer" id="lc-alts-drawer">
          <div class="lc-alts-grid" id="lc-alts-grid"></div>
        </div>
      </div>

      <div class="lc-meta" id="lc-meta" style="display:none;">
        <div class="lc-meta-row">
          <span class="lc-stars">★★★★★</span>
          <span class="lc-meta-text" id="lc-social-text"></span>
        </div>
        <div class="lc-scarcity-row">
          <div class="lc-scarcity-bar-wrap">
            <div class="lc-scarcity-bar" id="lc-scarcity-bar"></div>
          </div>
          <span class="lc-scarcity-text" id="lc-scarcity-text"></span>
        </div>
      </div>

      <div class="lc-cta" id="lc-cta" style="display:none;">
        <button class="lc-btn-add" id="lc-btn-add">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57L23 6H6"/></svg>
          <span class="lc-btn-text">Ja, voeg toe aan mijn bestelling</span>
        </button>
        <button class="lc-btn-skip" id="lc-btn-skip">Nee bedankt, ik mis deze deal</button>
      </div>

    </div>
  </div>
</div>
</div>

