<script>
(function () {
  const STORAGE_KEY = 'lc_dismissed_v10';
  const TIMER_KEY   = 'lc_timer_end_v10';
  const DURATION_MS = 12 * 60 * 1000;

  if (sessionStorage.getItem(STORAGE_KEY)) return;

  const source = document.getElementById('lc-teleport-source');
  if (!source) return;
  const popup = source.querySelector('#lc-popup');
  if (!popup) return;
  document.body.appendChild(popup);
  source.remove();

  const sheet      = popup.querySelector('#lc-sheet');
  const backdrop   = popup.querySelector('#lc-backdrop');
  const closeBtn   = popup.querySelector('#lc-close');
  const addBtn     = popup.querySelector('#lc-btn-add');
  const skipBtn    = popup.querySelector('#lc-btn-skip');
  const prodEl     = popup.querySelector('#lc-product');
  const metaEl     = popup.querySelector('#lc-meta');
  const ctaEl      = popup.querySelector('#lc-cta');
  const altsEl     = popup.querySelector('#lc-alts');
  const altsToggle = popup.querySelector('#lc-alts-toggle');
  const altsDrawer = popup.querySelector('#lc-alts-drawer');
  const altsGrid   = popup.querySelector('#lc-alts-grid');
  const cdM        = popup.querySelector('#lc-cd-m');
  const cdS        = popup.querySelector('#lc-cd-s');

  const sourceProductId = {{ lc_source_product_id | json }};

  let allProducts  = [];
  let activeIndex  = 0;

  function money(cents) {
    const n = parseInt(cents);
    if (!n || isNaN(n)) return '';
    return (n / 100).toFixed(2).replace('.', ',').replace(',00', ',-');
  }

  function dismiss() {
    sessionStorage.setItem(STORAGE_KEY, '1');
    popup.classList.remove('lc-visible');
    setTimeout(() => { try { popup.remove(); } catch(e){} }, 420);
  }

  // ── TIMER ──────────────────────────────────────────────────────
  let timerInterval = null;
  let expired = false;

  function startTimer() {
    let end = parseInt(sessionStorage.getItem(TIMER_KEY) || '0');
    if (!end || end <= Date.now()) {
      end = Date.now() + DURATION_MS;
      sessionStorage.setItem(TIMER_KEY, end);
    }
    function tick() {
      const diff = end - Date.now();
      if (diff <= 0) { onExpire(); return; }
      cdM.textContent = String(Math.floor(diff / 60000)).padStart(2,'0');
      cdS.textContent = String(Math.floor((diff % 60000) / 1000)).padStart(2,'0');
      if (diff < 60000 && diff > 59000) {
        sheet.classList.add('lc-shake');
        setTimeout(() => sheet.classList.remove('lc-shake'), 500);
      }
    }
    tick();
    timerInterval = setInterval(tick, 1000);
  }

  function onExpire() {
    clearInterval(timerInterval);
    expired = true;
    const label = popup.querySelector('.lc-timer-label');
    if (label) label.textContent = 'Deal verlopen';
    const cdWrap = popup.querySelector('.lc-countdown');
    if (cdWrap) cdWrap.style.opacity = '0.4';
    if (addBtn) {
      addBtn.disabled = true;
      addBtn.querySelector('.lc-btn-text').textContent = 'Deal verlopen';
    }
    setTimeout(dismiss, 3000);
  }

  // ── RENDER HOOFDPRODUCT ────────────────────────────────────────
  function renderProduct(d) {
    const savedCents = parseInt(d.oldPrice) - parseInt(d.price);
    const buyers = Math.floor(Math.random() * 251) + 100;
    const buyersDisplay = buyers % 10 === 0 ? buyers - Math.floor(Math.random() * 3) - 1 : buyers;
    const stock  = 2 + (parseInt(d.variantId) % 5);
    const stockPct = Math.round((stock / 10) * 100);

    prodEl.innerHTML = `
      <div class="lc-product-inner">
        <div class="lc-prod-img-wrap">
          <img class="lc-prod-img" src="${d.img}" alt="${d.title}" loading="eager" onerror="this.style.display='none'">
        </div>
        <div class="lc-prod-info">
          <span class="lc-prod-vendor">${d.vendor}</span>
          <span class="lc-prod-title">${d.title}</span>
          <div class="lc-pricing">
            <span class="lc-price-new">${money(d.price)}</span>
            <span class="lc-price-old">${money(d.oldPrice)}</span>
            <span class="lc-badge-pct">−5%</span>
          </div>
          <div class="lc-you-save">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Je bespaart ${money(savedCents)}
          </div>
        </div>
      </div>`;

    popup.querySelector('#lc-social-text').textContent = `${buyersDisplay} klanten kochten dit erbij`;
    popup.querySelector('#lc-scarcity-text').innerHTML = `Nog maar <strong>${stock} stuks</strong> beschikbaar — daarna weg`;
    metaEl.style.display = 'flex';

    setTimeout(() => {
      const bar = popup.querySelector('#lc-scarcity-bar');
      if (bar) bar.style.width = stockPct + '%';
    }, 400);

    ctaEl.style.display = 'flex';
    addBtn.dataset.variantId = d.variantId;
  }

  // ── RENDER ALTERNATIEVEN LIJST ─────────────────────────────────
  function renderAlts() {
    if (allProducts.length <= 1) return;
    altsEl.style.display = 'flex';
    altsGrid.innerHTML = '';

    allProducts.forEach((d, i) => {
      const btn = document.createElement('button');
      btn.className = 'lc-alt-item' + (i === activeIndex ? ' lc-alt-active' : '');
      btn.innerHTML = `
        <div class="lc-alt-img-wrap">
          <img class="lc-alt-img" src="${d.img}" alt="${d.title}" loading="lazy" onerror="this.style.display='none'">
        </div>
        <div class="lc-alt-info">
          <div class="lc-alt-title">${d.title}</div>
          <div>
            <span class="lc-alt-price">${money(d.price)}</span>
            <span class="lc-alt-price-old">${money(d.oldPrice)}</span>
          </div>
        </div>
        <div class="lc-alt-check">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>`;

      if (i !== activeIndex) {
        btn.addEventListener('click', () => {
          activeIndex = i;
          renderProduct(allProducts[i]);
          renderAlts();
          // Sluit drawer na keuze
          altsDrawer.classList.remove('lc-open');
          altsToggle.classList.remove('lc-open');
        });
      }

      altsGrid.appendChild(btn);
    });
  }

  // ── TOGGLE DRAWER ──────────────────────────────────────────────
  altsToggle.addEventListener('click', () => {
    const isOpen = altsDrawer.classList.contains('lc-open');
    altsDrawer.classList.toggle('lc-open', !isOpen);
    altsToggle.classList.toggle('lc-open', !isOpen);
  });

  // ── VERWERK PRODUCT DATA ───────────────────────────────────────
  function processProduct(p, cartProductIds) {
    if (!p.available || cartProductIds.has(p.id)) return null;
    const variant = p.variants && p.variants[0];
    if (!variant) return null;

    const basePrice  = parseInt(variant.price) || 0;
    const pct        = 5;
    const oldPrice   = basePrice;
    const finalPrice = Math.round(basePrice * 0.95);

    let img = '';
    if (p.featured_image) {
      img = typeof p.featured_image === 'string' ? p.featured_image : (p.featured_image.src || '');
    } else if (p.images && p.images.length) {
      img = typeof p.images[0] === 'string' ? p.images[0] : (p.images[0].src || '');
    }

    return { variantId: variant.id, price: finalPrice, oldPrice, pct, title: p.title, vendor: p.vendor, url: p.url || `/products/${p.handle}`, img };
  }

  // ── LADEN ──────────────────────────────────────────────────────
  function loadProduct() {
    if (!sourceProductId) { popup.remove(); return; }

    fetch('/cart.js')
      .then(r => r.json())
      .then(cart => {
        const cartProductIds = new Set(cart.items.map(i => i.product_id));
        const urls = [
          `/recommendations/products.json?product_id=${sourceProductId}&limit=5&intent=complementary`,
          `/recommendations/products.json?product_id=${sourceProductId}&limit=5`,
        ];
        return tryUrls(urls, cartProductIds);
      })
      .catch(() => { try { popup.remove(); } catch(e){} });
  }

  function tryUrls(urls, cartProductIds) {
    if (!urls.length) { try { popup.remove(); } catch(e){} return; }
    const [url, ...rest] = urls;

    return fetch(url)
      .then(r => r.json())
      .then(data => {
        const products = (data.products || [])
          .map(p => processProduct(p, cartProductIds))
          .filter(Boolean);

        if (!products.length) return tryUrls(rest, cartProductIds);

        allProducts = products;
        activeIndex = 0;
        renderProduct(allProducts[0]);
        renderAlts();
      })
      .catch(() => tryUrls(rest, cartProductIds));
  }

  // ── ADD TO CART ────────────────────────────────────────────────
  addBtn.addEventListener('click', function () {
    if (expired) return;
    const id = parseInt(addBtn.dataset.variantId);
    if (!id) return;
    const btnText = addBtn.querySelector('.lc-btn-text');
    const orig = btnText.textContent;
    btnText.textContent = 'Toevoegen…';
    addBtn.disabled = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ items: [{ id, quantity: 1 }], attributes: { 'lc-lastchance': 'true' } })
    })
    .then(r => r.ok ? r.json() : r.json().then(e => { throw new Error(e.message); }))
    .then(() => fetch('/cart.js').then(r => r.json()))
    .then(cart => {
      document.querySelectorAll('[data-cart-count],[data-cart-item-count],.cart-count,.cart__count,.header__cart-count,.cart-count-bubble').forEach(el => {
        el.textContent = cart.item_count;
        el.setAttribute('data-count', cart.item_count);
        if (cart.item_count > 0) el.removeAttribute('hidden');
      });
      btnText.textContent = '✓ Toegevoegd!';
      setTimeout(() => { window.location.reload(); }, 900);
    })
    .catch(() => {
      btnText.textContent = orig;
      addBtn.disabled = false;
    });
  });

  closeBtn.addEventListener('click', dismiss);
  skipBtn.addEventListener('click', dismiss);
  backdrop.addEventListener('click', dismiss);

  function showPopup() {
    loadProduct();
    requestAnimationFrame(() => requestAnimationFrame(() => {
      popup.classList.add('lc-visible');
      startTimer();
    }));
  }

  setTimeout(showPopup, 1500);
})();
</script>
{% endif %}